{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run lint && bun run format:check && bun run typecheck"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(./.env)"
    ]
  }
}