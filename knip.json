{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/routes/**/*.tsx",
    "src/sw.ts",
    "src/test/setup.ts",
    "src/mocks/supabase.ts",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.stories.tsx"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "tailwindcss",
    "i18next-parser",
    "@babel/preset-react",
    "@babel/preset-typescript",
    "babel-plugin-istanbul"
  ],
  "ignoreBinaries": ["wait-on"]
}
