{
  "name": "housekeeper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint --config oxlint.json src && eslint src && stylelint \"src/**/*.css\"",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run lint && bun run typecheck",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "knip": "knip",
    "mutation": "stryker run",
    "mutation:report": "bun run scripts/mutation-report.ts",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.ts && node scripts/fix-supabase-types.mjs",
    "test:db": "supabase test db",
    "release": "changelogen --release --push",
    "spec-drift-check": "node scripts/check-spec-drift.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/query-async-storage-persister": "5.101.4",
    "@tanstack/react-query": "5.101.4",
    "@tanstack/react-query-persist-client": "^5.100.8",
    "@tanstack/react-router": "^1.168.25",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.23.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.11.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@stryker-mutator/core": "^9.6.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "5.101.4",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.28",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "changelogen": "^0.6.2",
    "chromatic": "^18.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^17.5.0",
    "i18next-parser": "^9.4.0",
    "knip": "^6.17.1",
    "oxfmt": "^0.60.0",
    "oxlint": "1.75.0",
    "reg-cli": "^0.18.14",
    "storybook": "^10.3.5",
    "storycap": "^5.0.1",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0"
  }
}
